# Agnes AI (required for weather, photo analysis, outfits, try-on)
AGNES_API_KEY=your_agnes_api_key_here
AGNES_ENDPOINT=https://apihub.agnes-ai.com/v1/chat/completions
AGNES_IMAGE_ENDPOINT=https://apihub.agnes-ai.com/v1/images/generations

# Supabase — Fitz project (base URL only, no /rest/v1)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_jwt_anon_key_here
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Same values for the local API server (Hono)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_jwt_anon_key_here
# Required for outfit generation / wardrobe API (reads user KV store)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# API server port (default 3001, local dev only)
API_PORT=3001

# Google OAuth (Supabase Auth — also set in Supabase Dashboard → Auth → Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Production: leave VITE_API_BASE_URL empty when API is served from the same host (Vercel /api)
# VITE_API_BASE_URL=
